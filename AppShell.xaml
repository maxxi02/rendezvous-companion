<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="rendezvous_companion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:rendezvous_companion"
    xmlns:pages="clr-namespace:rendezvous_companion.Pages"
    Title="rendezvous_companion">

    <TabBar>
        <Tab Title="Orders" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate pages:OrdersPage}" />
        </Tab>
        <Tab Title="Settings" Icon="dotnet_bot.png">
            <ShellContent ContentTemplate="{DataTemplate pages:PrinterSettingsPage}" />
        </Tab>
    </TabBar>
</Shell>
