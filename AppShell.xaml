<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="rendezvous_companion.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:rendezvous_companion.Pages"
    Title="Rendezvous Companion">

    <TabBar>
        <Tab Title="Dashboard" Icon="tab_dashboard.png">
            <ShellContent ContentTemplate="{DataTemplate pages:DashboardPage}" />
        </Tab>
        <Tab Title="Settings" Icon="tab_settings.png">
            <ShellContent ContentTemplate="{DataTemplate pages:PrinterSettingsPage}" />
        </Tab>
    </TabBar>
</Shell>
