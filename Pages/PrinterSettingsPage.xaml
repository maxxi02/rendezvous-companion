<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  x:Class="rendezvous_companion.Pages.PrinterSettingsPage"
  Title="Printer Settings"
  BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}">

  <ScrollView>
    <VerticalStackLayout Padding="24" Spacing="24">

      <!-- Bluetooth Scan -->
      <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
        <VerticalStackLayout Spacing="16">
          <Grid ColumnDefinitions="*, Auto">
            <VerticalStackLayout>
              <Label Text="Bluetooth Printers" FontSize="20" FontAttributes="Bold"
                     TextColor="{StaticResource Primary}" />
              <Label Text="Auto-scans on open. Tap Scan to refresh."
                     FontSize="14" TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>
            <!-- Scan BT button with loading -->
            <Grid Grid.Column="1">
              <Button Text="Scan" Clicked="OnScanBluetoothClicked"
                      BackgroundColor="{StaticResource Primary}" TextColor="White"
                      CornerRadius="8" WidthRequest="80" HeightRequest="40" FontAttributes="Bold"
                      IsVisible="{Binding IsScanningBt, Converter={StaticResource InverseBoolConverter}}" />
              <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                      BackgroundColor="{StaticResource Gray400}"
                      WidthRequest="80" HeightRequest="40"
                      IsVisible="{Binding IsScanningBt}">
                <ActivityIndicator IsRunning="{Binding IsScanningBt}" Color="White"
                                   WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
              </Border>
            </Grid>
          </Grid>

          <Label x:Name="BtScanStatusLabel" Text="" TextColor="{StaticResource Gray500}"
                 FontSize="13" HorizontalTextAlignment="Center" />

          <CollectionView x:Name="BluetoothDevicesList" SelectionMode="None">
            <CollectionView.ItemTemplate>
              <DataTemplate>
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#C8C8C8, Dark=#404040}"
                        Padding="12" Margin="0,6"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#2C2C2C}">
                  <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                      <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"
                             TextColor="{StaticResource Gray900}" />
                      <Label Text="{Binding Id}" FontSize="12" TextColor="#404040" />
                      <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="{StaticResource Primary}" Padding="6,2">
                          <Label Text="BLUETOOTH" FontSize="10" FontAttributes="Bold" TextColor="White" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="#28a745" Padding="6,2"
                                IsVisible="{Binding IsPaired}">
                          <Label Text="PAIRED" FontSize="10" FontAttributes="Bold" TextColor="White" />
                        </Border>
                      </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                      <Button Text="Pair" CommandParameter="{Binding .}" Clicked="OnPairBluetoothClicked"
                              BackgroundColor="{StaticResource Primary}" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsVisible="{Binding IsPaired, Converter={StaticResource InverseBoolConverter}}" />
                      <Button Text="Receipt" CommandParameter="{Binding .}" Clicked="OnAssignReceiptClicked"
                              BackgroundColor="#28a745" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsEnabled="{Binding IsPaired}"
                              Opacity="{Binding IsPaired, Converter={StaticResource BoolToOpacityConverter}}" />
                      <Button Text="Kitchen" CommandParameter="{Binding .}" Clicked="OnAssignKitchenClicked"
                              BackgroundColor="#fd7e14" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsEnabled="{Binding IsPaired}"
                              Opacity="{Binding IsPaired, Converter={StaticResource BoolToOpacityConverter}}" />
                    </HorizontalStackLayout>
                  </Grid>
                </Border>
              </DataTemplate>
            </CollectionView.ItemTemplate>
          </CollectionView>
        </VerticalStackLayout>
      </Border>

      <!-- USB Scan -->
      <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
        <VerticalStackLayout Spacing="16">
          <Grid ColumnDefinitions="*, Auto">
            <VerticalStackLayout>
              <Label Text="USB Printers" FontSize="20" FontAttributes="Bold" TextColor="#198754" />
              <Label Text="Auto-scans on open. Tap Scan to refresh."
                     FontSize="14" TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>
            <!-- Scan USB button with loading -->
            <Grid Grid.Column="1">
              <Button Text="Scan" Clicked="OnScanUsbClicked"
                      BackgroundColor="#198754" TextColor="White"
                      CornerRadius="8" WidthRequest="80" HeightRequest="40" FontAttributes="Bold"
                      IsVisible="{Binding IsScanningUsb, Converter={StaticResource InverseBoolConverter}}" />
              <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                      BackgroundColor="{StaticResource Gray400}"
                      WidthRequest="80" HeightRequest="40"
                      IsVisible="{Binding IsScanningUsb}">
                <ActivityIndicator IsRunning="{Binding IsScanningUsb}" Color="White"
                                   WidthRequest="20" HeightRequest="20"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
              </Border>
            </Grid>
          </Grid>

          <Label x:Name="UsbScanStatusLabel" Text="" TextColor="{StaticResource Gray500}"
                 FontSize="13" HorizontalTextAlignment="Center" />

          <CollectionView x:Name="UsbDevicesList" SelectionMode="None">
            <CollectionView.ItemTemplate>
              <DataTemplate>
                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light=#C8C8C8, Dark=#404040}"
                        Padding="12" Margin="0,6"
                        BackgroundColor="{AppThemeBinding Light=#E1E1E1, Dark=#2C2C2C}">
                  <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                      <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"
                             TextColor="{StaticResource Gray900}" />
                      <Label Text="{Binding Id}" FontSize="12" TextColor="#404040" />
                      <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="#198754" Padding="6,2">
                          <Label Text="USB" FontSize="10" FontAttributes="Bold" TextColor="White" />
                        </Border>
                        <Border StrokeShape="RoundRectangle 4" BackgroundColor="#28a745" Padding="6,2"
                                IsVisible="{Binding IsPaired}">
                          <Label Text="PERMITTED" FontSize="10" FontAttributes="Bold" TextColor="White" />
                        </Border>
                      </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                      <Button Text="Pair" CommandParameter="{Binding .}" Clicked="OnPairUsbClicked"
                              BackgroundColor="#198754" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsVisible="{Binding IsPaired, Converter={StaticResource InverseBoolConverter}}" />
                      <Button Text="Receipt" CommandParameter="{Binding .}" Clicked="OnAssignReceiptClicked"
                              BackgroundColor="#28a745" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsEnabled="{Binding IsPaired}"
                              Opacity="{Binding IsPaired, Converter={StaticResource BoolToOpacityConverter}}" />
                      <Button Text="Kitchen" CommandParameter="{Binding .}" Clicked="OnAssignKitchenClicked"
                              BackgroundColor="#fd7e14" TextColor="White"
                              CornerRadius="6" FontSize="12" FontAttributes="Bold" Padding="12,6"
                              IsEnabled="{Binding IsPaired}"
                              Opacity="{Binding IsPaired, Converter={StaticResource BoolToOpacityConverter}}" />
                    </HorizontalStackLayout>
                  </Grid>
                </Border>
              </DataTemplate>
            </CollectionView.ItemTemplate>
          </CollectionView>
        </VerticalStackLayout>
      </Border>

      <!-- Current Assignments -->
      <Border StrokeShape="RoundRectangle 12" StrokeThickness="2"
              Stroke="{StaticResource Primary}"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
        <VerticalStackLayout Spacing="16">
          <Label Text="Current Assignments" FontSize="20" FontAttributes="Bold"
                 TextColor="{StaticResource Primary}" />
          <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
            <!-- Receipt -->
            <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                    Stroke="#28a745" Padding="12"
                    BackgroundColor="{AppThemeBinding Light=#F0F9F1, Dark=#0F2D15}">
              <VerticalStackLayout Spacing="8">
                <Label Text="RECEIPT" FontAttributes="Bold" TextColor="#28a745"
                       FontSize="12" HorizontalTextAlignment="Center" />
                <Label x:Name="ReceiptRoleLabel" Text="Not assigned" TextColor="Red"
                       FontSize="13" HorizontalTextAlignment="Center"
                       MaxLines="2" LineBreakMode="TailTruncation" HeightRequest="40" />
                <!-- Test Print with loading -->
                <Grid>
                  <Button x:Name="TestReceiptButton" Text="Test Print"
                          Clicked="OnTestReceiptClicked"
                          BackgroundColor="#17a2b8" TextColor="White"
                          CornerRadius="6" FontSize="11" Padding="4" IsEnabled="False"
                          IsVisible="{Binding IsTestingReceipt, Converter={StaticResource InverseBoolConverter}}" />
                  <Border StrokeShape="RoundRectangle 6" StrokeThickness="0"
                          BackgroundColor="{StaticResource Gray400}" Padding="4"
                          IsVisible="{Binding IsTestingReceipt}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                      <ActivityIndicator IsRunning="{Binding IsTestingReceipt}" Color="White"
                                         WidthRequest="12" HeightRequest="12" />
                      <Label Text="Printing..." FontSize="10" TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                  </Border>
                </Grid>
              </VerticalStackLayout>
            </Border>
            <!-- Kitchen -->
            <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                    Stroke="#fd7e14" Padding="12"
                    BackgroundColor="{AppThemeBinding Light=#FFF5EB, Dark=#2D1A0F}">
              <VerticalStackLayout Spacing="8">
                <Label Text="KITCHEN" FontAttributes="Bold" TextColor="#fd7e14"
                       FontSize="12" HorizontalTextAlignment="Center" />
                <Label x:Name="KitchenRoleLabel" Text="Not assigned" TextColor="Red"
                       FontSize="13" HorizontalTextAlignment="Center"
                       MaxLines="2" LineBreakMode="TailTruncation" HeightRequest="40" />
                <!-- Test Print with loading -->
                <Grid>
                  <Button x:Name="TestKitchenButton" Text="Test Print"
                          Clicked="OnTestKitchenClicked"
                          BackgroundColor="#17a2b8" TextColor="White"
                          CornerRadius="6" FontSize="11" Padding="4" IsEnabled="False"
                          IsVisible="{Binding IsTestingKitchen, Converter={StaticResource InverseBoolConverter}}" />
                  <Border StrokeShape="RoundRectangle 6" StrokeThickness="0"
                          BackgroundColor="{StaticResource Gray400}" Padding="4"
                          IsVisible="{Binding IsTestingKitchen}">
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                      <ActivityIndicator IsRunning="{Binding IsTestingKitchen}" Color="White"
                                         WidthRequest="12" HeightRequest="12" />
                      <Label Text="Printing..." FontSize="10" TextColor="White" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                  </Border>
                </Grid>
              </VerticalStackLayout>
            </Border>
          </Grid>
        </VerticalStackLayout>
      </Border>

      <!-- App Theme -->
      <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}" Padding="20">
        <VerticalStackLayout Spacing="12">
          <Label Text="App Theme" FontSize="20" FontAttributes="Bold"
                 TextColor="{StaticResource Primary}" />
          <Label Text="Choose how the app looks. System follows your device setting."
                 FontSize="14" TextColor="{StaticResource Gray500}" />
          <HorizontalStackLayout Spacing="10">
            <Button x:Name="ThemeSystemBtn" Text="System" Clicked="OnThemeSystemClicked"
                    CornerRadius="8" HeightRequest="40" FontAttributes="Bold" Padding="16,0" />
            <Button x:Name="ThemeLightBtn" Text="Light" Clicked="OnThemeLightClicked"
                    CornerRadius="8" HeightRequest="40" FontAttributes="Bold" Padding="16,0" />
            <Button x:Name="ThemeDarkBtn" Text="Dark" Clicked="OnThemeDarkClicked"
                    CornerRadius="8" HeightRequest="40" FontAttributes="Bold" Padding="16,0" />
          </HorizontalStackLayout>
        </VerticalStackLayout>
      </Border>

      <!-- Danger Zone -->
      <Border StrokeShape="RoundRectangle 12" StrokeThickness="0"
              BackgroundColor="{AppThemeBinding Light=#FFEBEB, Dark=#3D1B1B}"
              Padding="20" Margin="0,10,0,0">
        <VerticalStackLayout Spacing="12">
          <Label Text="System Control" FontSize="18" FontAttributes="Bold" TextColor="#DC3545" />
          <Label Text="The companion app normally runs forever in the background to ensure your printers never disconnect. Use this button if you need to completely stop the app and its background service."
                 FontSize="13" TextColor="{AppThemeBinding Light=#8B2121, Dark=#FFB3B3}" />
          <Button Text="Shutdown App &amp; Service"
                  Clicked="OnExitAppClicked"
                  BackgroundColor="#DC3545" TextColor="White"
                  CornerRadius="8" HeightRequest="48" FontAttributes="Bold" Margin="0,10,0,0" />
        </VerticalStackLayout>
      </Border>

    </VerticalStackLayout>
  </ScrollView>
</ContentPage>
