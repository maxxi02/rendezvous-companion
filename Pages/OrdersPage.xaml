<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:models="clr-namespace:rendezvous_companion.Models"
  xmlns:conv="clr-namespace:rendezvous_companion.Converters"
  x:Class="rendezvous_companion.Pages.OrdersPage"
  Title="Active Orders"
  BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}">

  <ContentPage.Resources>
    <conv:QueueStatusColorConverter x:Key="StatusColorConverter" />
    <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
  </ContentPage.Resources>

  <Grid RowDefinitions="Auto, *">

    <!-- Header -->
    <Border Grid.Row="0" Margin="16,16,16,8" Padding="14"
            StrokeShape="RoundRectangle 10" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
      <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
        <BoxView Grid.Column="0" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                 VerticalOptions="Center" Color="{Binding ConnectionStatusColor}" />
        <Label Grid.Column="1" Text="{Binding StatusMessage}"
               VerticalOptions="Center" FontAttributes="Bold" />
        <Label Grid.Column="2" Text="{Binding Orders.Count, StringFormat='{0} orders'}"
               FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
      </Grid>
    </Border>

    <!-- Orders List -->
    <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding RefreshCommand}">
      <CollectionView ItemsSource="{Binding Orders}" Margin="16,0,16,16">
        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="models:Order">
            <SwipeView Margin="0,0,0,10">

              <SwipeView.LeftItems>
                <SwipeItems Mode="Execute">
                  <SwipeItem Text="Preparing" BackgroundColor="#fd7e14"
                             CommandParameter="{Binding .}"
                             Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkPreparingCommand}" />
                </SwipeItems>
              </SwipeView.LeftItems>

              <SwipeView.RightItems>
                <SwipeItems Mode="Execute">
                  <SwipeItem Text="Serving" BackgroundColor="#17a2b8"
                             CommandParameter="{Binding .}"
                             Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkServingCommand}" />
                  <SwipeItem Text="Done" BackgroundColor="#28a745"
                             CommandParameter="{Binding .}"
                             Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.MarkCompletedCommand}" />
                </SwipeItems>
              </SwipeView.RightItems>

              <Border Padding="14" StrokeShape="RoundRectangle 12" StrokeThickness="2"
                      Stroke="{Binding QueueStatus, Converter={StaticResource StatusColorConverter}}"
                      BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
                <VerticalStackLayout Spacing="10">

                  <!-- Order info row -->
                  <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                      <Label Text="{Binding OrderNumber}" FontSize="18" FontAttributes="Bold" />
                      <Label Text="{Binding CustomerName}" FontSize="13"
                             TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                      <Label Text="{Binding TableNumber, StringFormat='Table {0}'}"
                             FontSize="14" FontAttributes="Bold" HorizontalOptions="End" />
                      <Border StrokeShape="RoundRectangle 4" Padding="6,2" HorizontalOptions="End"
                              BackgroundColor="{Binding QueueStatus, Converter={StaticResource StatusColorConverter}}">
                        <Label Text="{Binding QueueStatus}" FontSize="10"
                               FontAttributes="Bold" TextColor="White" TextTransform="Uppercase" />
                      </Border>
                    </VerticalStackLayout>
                  </Grid>

                  <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />

                  <!-- Action Buttons with loading states -->
                  <Grid ColumnDefinitions="*, *" ColumnSpacing="10">

                    <!-- Receipt button -->
                    <Grid Grid.Column="0">
                      <Button Text="🖨 Receipt"
                              Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrintReceiptCommand}"
                              CommandParameter="{Binding .}"
                              BackgroundColor="#3498DB" TextColor="White"
                              CornerRadius="8" HeightRequest="44" FontSize="13"
                              IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingReceipt, Converter={StaticResource InverseBoolConverter}}"
                              Opacity="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingReceipt, Converter={StaticResource BoolToOpacityConverter}}" />
                      <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                              BackgroundColor="{StaticResource Gray400}" HeightRequest="44"
                              IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingReceipt}">
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                          <ActivityIndicator IsRunning="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingReceipt}"
                                             Color="White" WidthRequest="16" HeightRequest="16" />
                          <Label Text="Printing..." FontSize="12" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                      </Border>
                    </Grid>

                    <!-- Kitchen button -->
                    <Grid Grid.Column="1">
                      <Button Text="🍳 Kitchen"
                              Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrintKitchenCommand}"
                              CommandParameter="{Binding .}"
                              BackgroundColor="#E67E22" TextColor="White"
                              CornerRadius="8" HeightRequest="44" FontSize="13"
                              IsEnabled="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingKitchen, Converter={StaticResource InverseBoolConverter}}"
                              Opacity="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingKitchen, Converter={StaticResource BoolToOpacityConverter}}" />
                      <Border StrokeShape="RoundRectangle 8" StrokeThickness="0"
                              BackgroundColor="{StaticResource Gray400}" HeightRequest="44"
                              IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingKitchen}">
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                          <ActivityIndicator IsRunning="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsPrintingKitchen}"
                                             Color="White" WidthRequest="16" HeightRequest="16" />
                          <Label Text="Printing..." FontSize="12" TextColor="White" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                      </Border>
                    </Grid>

                  </Grid>

                  <Label Text="← Swipe to update status →" FontSize="10"
                         TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
              </Border>
            </SwipeView>
          </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
          <VerticalStackLayout Padding="50" HorizontalOptions="Center" VerticalOptions="Center">
            <Label Text="No active orders" FontSize="18"
                   HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />
            <Label Text="Orders will appear here as they come in."
                   FontSize="13" HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />
          </VerticalStackLayout>
        </CollectionView.EmptyView>
      </CollectionView>
    </RefreshView>

  </Grid>
</ContentPage>
