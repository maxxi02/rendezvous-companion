<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:rendezvous_companion.Models"
             x:Class="rendezvous_companion.Pages.OrdersPage"
             Title="Active Orders"
             BackgroundColor="#F5F5F7">

    <Grid RowDefinitions="Auto, *">
        <!-- Header / Status -->
        <Border Grid.Row="0" Margin="10" Padding="15" StrokeShape="RoundRectangle 10">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
            </Border.Shadow>
            <HorizontalStackLayout Spacing="10">
                <BoxView WidthRequest="12" HeightRequest="12" CornerRadius="6" VerticalOptions="Center" 
                         Color="{Binding ConnectionStatusColor}" />
                <Label Text="{Binding StatusMessage}" VerticalOptions="Center" FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Border>

        <!-- Orders List -->
        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsRefreshing}" Command="{Binding RefreshCommand}">
            <CollectionView ItemsSource="{Binding Orders}" Margin="5">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Order">
                        <Border Margin="5" Padding="15" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <VerticalStackLayout Grid.Column="0">
                                        <Label Text="{Binding OrderNumber}" FontSize="20" FontAttributes="Bold" TextColor="#2C3E50" />
                                        <Label Text="{Binding CustomerName}" FontSize="14" TextColor="#7F8C8D" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End">
                                        <Label Text="{Binding TableNumber, StringFormat='Table {0}'}" FontSize="16" FontAttributes="Bold" HorizontalOptions="End" />
                                        <Label Text="{Binding QueueStatus}" FontSize="12" TextTransform="Uppercase" HorizontalOptions="End" />
                                    </VerticalStackLayout>
                                </Grid>

                                <BoxView HeightRequest="1" Color="#EEEEEE" />

                                <!-- Action Buttons -->
                                <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                    <Button Grid.Column="0" Text="Receipt" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrintReceiptCommand}" 
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#3498DB" TextColor="White" CornerRadius="8" HeightRequest="45" />

                                    <Button Grid.Column="1" Text="Kitchen" 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.PrintKitchenCommand}" 
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="#E67E22" TextColor="White" CornerRadius="8" HeightRequest="45" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout Padding="50" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="No active orders" FontSize="18" HorizontalOptions="Center" TextColor="#BDC3C7" />
                        <Label Text="Orders will appear here as they are created in the POS." FontSize="14" HorizontalOptions="Center" TextColor="#BDC3C7" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
