<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
  xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
  xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
  xmlns:models="clr-namespace:rendezvous_companion.Models"
  x:Class="rendezvous_companion.Pages.PrintQueuePage"
  Title="Print Queue"
  BackgroundColor="{AppThemeBinding Light=#F3F4F6, Dark=#121212}">

  <Grid RowDefinitions="Auto, *">

    <!-- Summary bar -->
    <Border Grid.Row="0" Margin="16,16,16,0" Padding="16"
            StrokeShape="RoundRectangle 10" StrokeThickness="0"
            BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
      <Grid ColumnDefinitions="*, Auto">
        <VerticalStackLayout Grid.Column="0" Spacing="2">
          <Label Text="{Binding SummaryText}" FontAttributes="Bold" FontSize="15" />
          <Label Text="Tap Retry to resend a failed job" FontSize="12"
                 TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>
        <Button Grid.Column="1" Text="Retry All" Clicked="OnRetryAllClicked"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                CornerRadius="8" FontSize="12" Padding="12,6"
                IsEnabled="{Binding HasFailed}" />
      </Grid>
    </Border>

    <!-- Queue list -->
    <CollectionView Grid.Row="1" ItemsSource="{Binding QueueItems}" Margin="16,12,16,16">
      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="models:PrintQueueItem">
          <Border Margin="0,0,0,10" Padding="14" StrokeShape="RoundRectangle 10"
                  StrokeThickness="1" Stroke="{Binding StatusColor}"
                  BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}">
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

              <!-- Status dot -->
              <BoxView Grid.Column="0" WidthRequest="12" HeightRequest="12" CornerRadius="6"
                       VerticalOptions="Center" Color="{Binding StatusColor}" />

              <!-- Info -->
              <VerticalStackLayout Grid.Column="1" Spacing="2">
                <Label Text="{Binding OrderNumber}" FontAttributes="Bold" FontSize="15" />
                <Label Text="{Binding CustomerName}" FontSize="13"
                       TextColor="{StaticResource Gray500}" />
                <HorizontalStackLayout Spacing="8" Margin="0,4,0,0">
                  <Border StrokeShape="RoundRectangle 4" Padding="6,2"
                          BackgroundColor="{Binding StatusColor}">
                    <Label Text="{Binding StatusLabel}" FontSize="10"
                           FontAttributes="Bold" TextColor="White" />
                  </Border>
                  <Border StrokeShape="RoundRectangle 4" Padding="6,2"
                          BackgroundColor="{StaticResource Secondary}">
                    <Label Text="{Binding JobType}" FontSize="10"
                           FontAttributes="Bold" TextColor="White" />
                  </Border>
                </HorizontalStackLayout>
                <Label Text="{Binding CreatedAt, StringFormat='{0:hh:mm tt · MMM dd}'}"
                       FontSize="11" TextColor="{StaticResource Gray500}" />
              </VerticalStackLayout>

              <!-- Actions -->
              <VerticalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                <Button Text="Retry"
                        CommandParameter="{Binding .}"
                        Clicked="OnRetryClicked"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White" CornerRadius="6"
                        FontSize="12" Padding="10,4"
                        IsVisible="{Binding Status, Converter={StaticResource IsFailedConverter}}" />
                <Button Text="✕"
                        CommandParameter="{Binding .}"
                        Clicked="OnDismissClicked"
                        BackgroundColor="{StaticResource Gray500}"
                        TextColor="White" CornerRadius="6"
                        FontSize="12" Padding="10,4" />
              </VerticalStackLayout>

            </Grid>
          </Border>
        </DataTemplate>
      </CollectionView.ItemTemplate>

      <CollectionView.EmptyView>
        <VerticalStackLayout Padding="40" HorizontalOptions="Center" VerticalOptions="Center">
          <Label Text="✓" FontSize="48" HorizontalOptions="Center"
                 TextColor="{StaticResource Primary}" />
          <Label Text="No pending print jobs" FontSize="16"
                 HorizontalOptions="Center" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>
      </CollectionView.EmptyView>
    </CollectionView>

  </Grid>
</ContentPage>
